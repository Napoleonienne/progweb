  <!-- C'est rigolo, il y a un script à l'adresse https://vincentjuge1987.github.io/td/src/td03/graph.js -->
  <script  defer>
   "use strict";

   const sum = function(a, b) {
    return a + b;
}
const pgcd = function(a, b) {
    if (b==0) {
    return a;
    }
    return pgcd(b,a%b);

};
const isPrime = function(a) {
    // Écrire le corps de la fonction ici.
    const primes = listPrimes(a+1);

    if (primes.includes(a)) {
        return true;
    }
    return false;
}

    
const listPrimes = function(a) {
    
    let io = new Uint8Array(a).fill(1);
    io[0] = 0;
    io[1] = 0;
    for(let i =2 ; i<a**0.5;i++){
      if (io[i]) {
            for (let p= i**2;p<a;p+=i) {
            io[p] = 0;
            };
    };
   };
   var res = [];
    for (let index = 0; index < io.length; index++) {
    if (io[index]) {
        res.push(index);
    }
   
    
}
   return res;
}

window.addEventListener('DOMContentLoaded', () => {

    const btn1 = document.querySelector('#button1');
    btn1.addEventListener("click", () => {
        const val1 = Number(document.querySelector('#area1').value);
        const val2 = Number(document.querySelector('#area2').value);
        document.querySelector("#area3").textContent = sum(val1, val2);
    });

    const btn2 = document.querySelector('#button2');
    btn2.addEventListener("click", () => {
        const val4 = Number(document.querySelector('#area4').value);
        const val5 = Number(document.querySelector('#area5').value);
        document.querySelector("#area6").textContent = pgcd(val4, val5);
    });

    const btn3 = document.querySelector('#button3');
    btn3.addEventListener("click", () => {
        const val7 = Number(document.querySelector('#area7').value);
        const result = isPrime(val7);
        const target = document.querySelector("#area8");
        
        target.textContent = result ? "Oui, il est premier." : "Non, il est divisible.";
        target.className = result ? "oui" : "non";
    });

    const btn4 = document.querySelector('#button4');
    btn4.addEventListener("click", () => {
        const val9 = Number(document.querySelector('#area9').value);
        const primes = listPrimes(val9);
        document.querySelector("#area10").textContent = primes.join(", ");
    });

});



   </script>
 </head>
 <body>

  <h2>Somme</h2>
  <p class="large">
    <textarea id="area1" rows="1" cols="6"></textarea>&nbsp;+&nbsp;<textarea id="area2" rows="1" cols="6"></textarea>&nbsp; = <span id="area3"></span>
  </p>
  <p class="large button" id="button1">
    C'est parti !
  </p>
  <br>



  <h2>PGCD</h2>
  <p class="large">
    PGCD(&nbsp;<textarea id="area4" rows="1" cols="6"></textarea>&nbsp;,&nbsp;<textarea id="area5" rows="1" cols="6"></textarea>&nbsp;) = <span id="area6"></span>
  </p>
  <p class="large button" id="button2">
    C'est parti !
  </p>
  <br>



  <h2>Premier ou pas ?</h2>
  <p class="large">
    <textarea id="area7" rows="1" cols="6"></textarea>&nbsp;est-il un nombre premier ? <span id="area8"></span>
  </p>
  <p class="large button" id="button3">
    C'est parti !
  </p>
  <br>


  
  <h2>Liste des nombres premiers</h2>
  <p class="large">
    Nombres premiers jusqu'à&nbsp;<textarea id="area9" rows="1" cols="6"></textarea>&nbsp;:&nbsp;&nbsp;<span id="area10"></span>
  </p>
  <p class="large button" id="button4">
    C'est parti !
  </p>
